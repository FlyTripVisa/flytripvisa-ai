{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "flytripvisa-ai",
  "main": "worker/index.js",
  "compatibility_date": "2025-02-04",
  "compatibility_flags": ["nodejs_compat"],

  // ── D1 Database ──
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "flydb-d1",
      "database_id": "bc449b24-09b3-4ecd-a599-b78d0127f594"
    }
  ],

  // ── KV Namespace ──
  "kv_namespaces": [
    {
      "binding": "KV",
      "id": "2085403b5d774d1bbd333bcb8ea0d80b"
    }
  ],

  // ── R2 Bucket ──
  "r2_buckets": [
    {
      "binding": "ASSETS",
      "bucket_name": "flytripvisa-assets"
    }
  ],

  // ── Workers AI ──
  "ai": {
    "binding": "AI"
  },

  // ── Non-secret configuration ──
  "vars": {
    "AI_CHAT_MODEL": "@cf/meta/llama-3.3-70b-instruct-fp8-fast",
    "AI_EMBEDDING_MODEL": "@cf/qwen/qwen3-embedding-0.6b",
    "AI_RERANKER_MODEL": "@cf/baai/bge-reranker-base",
    "AI_SEARCH_ENDPOINT": "https://77d69b53-4c9b-400e-a376-c42a65a7d9a1.search.ai.cloudflare.com/chat/completions",
    "R2_ENDPOINT": "https://b73b80fa62deef032d3c08248cf2f30b.r2.cloudflarestorage.com"
  }
};