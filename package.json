{
  "name": "flytripvisa-ai",
  "version": "1.0.0",
  "description": "FlyTripVisa AI Full-Stack Platform",
  "main": "worker/index.js",
  "scripts": {
    "dev": "concurrently \"next dev\" \"wrangler dev worker/index.js\"",
    "build": "next build",
    "start": "next start",
    "deploy:worker": "wrangler deploy worker/index.js",
    "db:migrate": "wrangler d1 migrations apply flydb-d1 --local",
    "db:migrate:remote": "wrangler d1 migrations apply flydb-d1 --remote"
  },
  "dependencies": {
    "next": "15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.0",
    "lucide-react": "^0.450.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250204.0",
    "wrangler": "^3.100.0",
    "typescript": "^5.0.0",
    "concurrently": "^9.0.0"
  }
}
